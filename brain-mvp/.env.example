# Brain MVP Environment Configuration
# Copy this file to .env and update the values

# Application Settings
ENVIRONMENT=development
SECRET_KEY=your-super-secret-key-change-this-in-production
DEBUG=true
LOG_LEVEL=INFO

# Database Configuration
POSTGRES_PASSWORD=brain_password_change_this
DATABASE_URL=postgresql://brain_user:brain_password_change_this@postgres:5432/brain_mvp

# Redis Configuration
REDIS_PASSWORD=redis_password_change_this
REDIS_URL=redis://:redis_password_change_this@redis:6379/0

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# File Upload Settings
MAX_FILE_SIZE=100MB
UPLOAD_DIR=/app/uploads
PROCESSED_DIR=/app/processed

# AI/ML Settings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_CACHE_DIR=/app/data/embeddings

# Monitoring (Optional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
GRAFANA_PASSWORD=admin_password_change_this

# Security
JWT_SECRET_KEY=jwt-secret-key-change-this
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# External Services (Optional)
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key

# Backup Settings
BACKUP_SCHEDULE=0 2 * * *  # Daily at 2 AM
BACKUP_RETENTION_DAYS=30