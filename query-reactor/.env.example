# QueryReactor Environment Variables Template
# Copy this file to .env and fill in your actual values

# OpenAI API Configuration
# Note: QueryReactor is configured for GPT-5-Nano compatibility
# GPT-5-Nano uses max_completion_tokens (not max_tokens) and default temperature only
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ORG_ID=your_openai_org_id_here

# Anthropic API Configuration  
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/queryreactor
REDIS_URL=redis://localhost:6379/0

# External Search APIs
# Required for M5 Internet Retrieval module (now using Perplexity)
PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Legacy Google Search API (kept for reference)
# GOOGLE_SEARCH_API_KEY=your_google_search_api_key_here
# GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# Optional Search APIs
# BING_SEARCH_API_KEY=your_bing_search_api_key_here  # Optional - Not used in V1.0


# Logging and Monitoring
LOG_LEVEL=INFO
SENTRY_DSN=your_sentry_dsn_here

# LangSmith Configuration (Recommended for LangGraph monitoring)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=queryreactor

# OpenTelemetry Configuration (Optional - for general observability)
OTEL_SERVICE_NAME=queryreactor
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Security
SECRET_KEY=your_secret_key_for_jwt_tokens
ALLOWED_HOSTS=localhost,127.0.0.1

# Brain-MVP Integration
BRAIN_MVP_API_URL=http://localhost:8088

# Development Settings
DEBUG=false
ENVIRONMENT=production